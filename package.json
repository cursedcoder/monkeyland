{
  "name": "monkeyland",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:rust": "cd src-tauri && LLVM_COV=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/lib/rustlib/aarch64-apple-darwin/bin/llvm-cov LLVM_PROFDATA=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/lib/rustlib/aarch64-apple-darwin/bin/llvm-profdata cargo llvm-cov --lib",
    "test:coverage:rust:html": "cd src-tauri && LLVM_COV=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/lib/rustlib/aarch64-apple-darwin/bin/llvm-cov LLVM_PROFDATA=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/lib/rustlib/aarch64-apple-darwin/bin/llvm-profdata cargo llvm-cov --lib --html && open target/llvm-cov/html/index.html",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:icon": "tauri icon public/favicon.svg",
    "validate:no-errors": "node scripts/validate-no-console-errors.mjs",
    "beads:install": "npm install -g @beads/bd",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/openai": "^3.0.37",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.105",
    "multi-llm-ts": "^5.1.0-beta4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "bash -c 'npm run typecheck'",
    "src-tauri/**/*.rs": "bash -c 'cd src-tauri && cargo fmt -- --check && cargo check'"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.3.1",
    "playwright": "^1.58.2",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  }
}
